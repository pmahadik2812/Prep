## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2019/2022 cache/options directory
.vs/

# Visual Studio Code settings
.vscode/

# Rider settings
.idea/

# Generated build files
*.dll
*.exe
*.app
*.appx
*.apk
*.so
*.dylib
*.pdb
*.cache
*.tmp
*.dbmdl
*.bak
*.log

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# NuGet
*.nupkg
*.snupkg
# The packages folder can be ignored if restore is used
**/[Pp]ackages/*
!**/[Pp]ackages/build/
# NuGet v3's project.json files
project.lock.json
project.fragment.lock.json
artifacts/

# Microsoft Azure Web App publish settings
*.PublishSettings
PublishProfiles/

# Coverage results
*.coverage
*.coveragexml

# DotCover
.idea/.idea.DotSettings

# NCrunch
_nCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# Others
*.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper

# Dotnet tools
.dotnet/
tools/

# Local test runs
TestResult*/
TestResults/

# Entity Framework Core Migrations
[Mm]igrations/

# Docker
docker-compose.override.yml
.docker/

# Secrets
secrets.json

# IIS
.vsconfig
appsettings.Development.json

